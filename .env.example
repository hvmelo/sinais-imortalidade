# Environment Variables — Sinais de Imortalidade
#
# Copy this file to .env.local for local development.
# Never commit .env.local to the repository.
#
# Phase 1: No environment variables required.
# This file documents the pattern for future phases.
#
# Example for future phases:
# NEXT_PUBLIC_SITE_URL=https://sinais-de-imortalidade.vercel.app
# NEWSLETTER_API_KEY=your_key_here
